# Backend Environment Variables

# Server Configuration
PORT=4000
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Production Frontend URL
# FRONTEND_URL=https://inventory-f8f66.web.app

# Firebase Admin SDK (if needed for backend operations)
# FIREBASE_PROJECT_ID=inventory-f8f66
# FIREBASE_CLIENT_EMAIL=your-service-account@inventory-f8f66.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload Limits
MAX_FILE_SIZE_MB=10
